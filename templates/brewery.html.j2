<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ brewery.name_zhtw or brewery.name_jp }}｜日本酒造資料庫</title>
<link rel="stylesheet" href="{{ page_path }}styles.css">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
<header class="site-header">
  <div class="container">
    <h1 class="site-title"><a href="{{ page_path }}index.html">日本酒造資料庫</a></h1>
  </div>
</header>

{# ===== 酒造 Hero ===== #}
<section class="brewery-hero">
  <div class="hero-bg" style="background-image: url('{{ brewery._hero_image }}');"></div>
  <div class="hero-overlay"></div>
  <div class="hero-vignette"></div>

  <div class="container hero-content">
    <nav class="breadcrumb breadcrumb-light">
      <a href="{{ page_path }}index.html">首頁</a>
      <span class="sep">›</span>
      <a href="{{ page_path }}regions/{{ brewery.region_zhtw | safe_id }}/">{{ brewery.region_zhtw }}</a>
      <span class="sep">›</span>
      <span class="current">{{ brewery.area_zhtw or brewery.area_jp }}</span>
    </nav>

    <h1 class="brewery-hero-title">{{ brewery.name_zhtw or brewery.name_jp }}</h1>
    {% if brewery.name_zhtw and brewery.name_zhtw != brewery.name_jp %}
    <p class="brewery-hero-jp">{{ brewery.name_jp }}</p>
    {% endif %}

    <div class="brewery-meta-row">
      <span>📍 {{ brewery.area_zhtw or brewery.area_jp }}</span>
      {% if brewery.founded_year %}
      <span>🏯 創業 {{ brewery.founded_year }}</span>
      {% endif %}
      {% if brewery.website %}
      <span>🔗 <a href="{{ brewery.website }}" rel="noopener" target="_blank">官網</a></span>
      {% endif %}
    </div>
  </div>
</section>

<main class="container">

{% if products %}
<section class="products-section">
  <h2 class="section-title">旗下銘柄 <span class="section-count">{{ products|length }}</span></h2>

  <div class="product-grid">
    {% for product in products %}
    {% set theme = product._theme %}
    <a href="{{ page_path }}products/{{ product.product_id | safe_id }}.html" class="product-card">
      <div class="product-card-visual" style="background: {{ theme.bg_gradient }};">
        {% if product._authorized_image %}
          <img src="{{ page_path }}{{ product._authorized_image }}" alt="{{ product.name_zhtw or product.name_jp }}" class="product-card-img">
        {% else %}
          <div class="mini-sake-card" style="background: linear-gradient(180deg, {{ theme.primary }} 0%, {{ theme.secondary }} 100%);">
            <div class="mini-sake-label">{{ theme.label }}</div>
            <div class="mini-sake-name">{{ product.name_zhtw or product.name_jp }}</div>
            <div class="mini-sake-divider"></div>
            <div class="mini-sake-brewery">{{ product.brewery_name_jp }}</div>
          </div>
        {% endif %}
      </div>

      <div class="product-card-body">
        <h3 class="product-card-name">{{ product.name_zhtw or product.name_jp }}</h3>
        <p class="product-card-jp">{% if product.name_zhtw and product.name_zhtw != product.name_jp %}{{ product.name_jp }}{% else %}&nbsp;{% endif %}</p>

        <dl class="product-quickspec">
          {% if product.sake_type %}<div><dt>類型</dt><dd>{{ product.sake_type }}</dd></div>{% endif %}
          {% if product.rice_variety %}<div><dt>米</dt><dd>{{ product.rice_variety }}</dd></div>{% endif %}
          {% if product.seimaibuai %}<div><dt>精米</dt><dd>{{ product.seimaibuai }}%</dd></div>{% endif %}
        </dl>

        {% if product.flavor_tags %}
        <div class="flavor-tags-mini">
          {% for tag in product.flavor_tags.split(',')[:3] %}
          {% if tag.strip() %}<span class="tag-mini">{{ tag.strip() }}</span>{% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% else %}
<section class="empty-state">
  <p>此酒造目前尚無銘柄資料</p>
</section>
{% endif %}

</main>

<footer class="site-footer">
  <div class="container">
    <p><a href="{{ page_path }}index.html">← 返回首頁</a></p>
    {% if brewery.sakenowa_brewery_url %}
    <p class="footer-meta"><a href="{{ brewery.sakenowa_brewery_url }}" rel="noopener" target="_blank">在 Sakenowa 查看此酒造 →</a></p>
    {% endif %}
    <p class="footer-meta">最後更新:{{ generated_at }}</p>
  </div>
</footer>

{% include '_warning_bar.html.j2' %}
</body>
</html>
