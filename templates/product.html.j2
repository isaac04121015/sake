<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ product.name_zhtw or product.name_jp }}｜{{ product.brewery_name_jp }}</title>
{% if product.description %}<meta name="description" content="{{ product.description[:140] }}">{% endif %}
<link rel="stylesheet" href="{{ page_path }}styles.css">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
<header class="site-header">
  <div class="container">
    <h1 class="site-title"><a href="{{ page_path }}index.html">日本酒造資料庫</a></h1>
  </div>
</header>

{% set theme = product._theme %}

{# ===== 三欄 Hero (照 Claude Design) ===== #}
<section class="product-hero" style="background: {{ theme.bg_gradient }};">
  <div class="container">

    {# 麵包屑 - 置於 hero 區頂部 #}
    <nav class="breadcrumb breadcrumb-hero-top">
      <a href="{{ page_path }}index.html">首頁</a>
      <span class="sep">›</span>
      {% if brewery.region_zhtw %}
      <a href="{{ page_path }}regions/{{ brewery.region_zhtw | safe_id }}/">{{ brewery.region_zhtw }}</a>
      <span class="sep">›</span>
      {% endif %}
      <a href="{{ page_path }}breweries/{{ product.brewery_id | safe_id }}.html">{{ product.brewery_name_jp }}</a>
    </nav>

    <div class="product-hero-3col">

      {# 左欄:圖片佔位區 (image-slot 風格) #}
      <div class="bottle-slot-wrap">
        <span class="bottle-slot-label">酒瓶照片</span>
        {% if product._authorized_image %}
          {# 有授權圖時直接顯示 #}
          <div class="image-slot image-slot-filled">
            <img src="{{ page_path }}{{ product._authorized_image }}" alt="{{ product.name_zhtw or product.name_jp }}">
          </div>
        {% else %}
          {# 沒圖時:顯示虛線框 + 上傳提示 (visual only) #}
          <div class="image-slot image-slot-empty">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <path d="m21 15-5-5L5 21"/>
            </svg>
            <div class="image-slot-caption">拖曳酒瓶照片至此</div>
            <div class="image-slot-spec">{{ product.product_id }} · 600×800px</div>
          </div>
        {% endif %}
      </div>

      {# 中欄:CSS 設計卡片 #}
      <div class="sake-card-zone">
        <div class="sake-card" style="background: linear-gradient(180deg, {{ theme.primary }} 0%, {{ theme.secondary }} 100%);">
          <div class="sake-card-inner">
            <div class="sake-card-label">{{ theme.label }}</div>
            <div class="sake-card-name">{{ product.name_zhtw or product.name_jp }}</div>
            {% if product.name_zhtw and product.name_zhtw != product.name_jp %}
            <div class="sake-card-jp">{{ product.name_jp }}</div>
            {% endif %}
            <div class="sake-card-divider"></div>
            <div class="sake-card-brewery">{{ product.brewery_name_jp }}</div>
            <div class="sake-card-area">{{ product.area_zhtw or product.area_jp }}</div>
          </div>
        </div>
      </div>

      {# 右欄:資訊區 (不再有麵包屑) #}
      <div class="product-info-col">
        <h1 class="product-title">{{ product.name_zhtw or product.name_jp }}</h1>
        {% if product.name_zhtw and product.name_zhtw != product.name_jp %}
        <p class="product-title-jp">{{ product.name_jp }}</p>
        {% endif %}

        <p class="product-brewery-line">
          <a href="{{ page_path }}breweries/{{ product.brewery_id | safe_id }}.html">{{ product.brewery_name_jp }}</a>
          <span class="sep">·</span>
          <span>{{ product.area_zhtw or product.area_jp }}</span>
        </p>

        {# 星級評分 (來自精選銘柄清單) #}
        {% if product._stars and product._stars > 0 %}
        <div class="star-row">
          {% for i in range(5) %}
            <span class="star {% if i < product._stars %}full{% else %}empty{% endif %}" style="font-size: 20px;">★</span>
          {% endfor %}
          <span class="star-label">{{ product._stars }}/5 推薦</span>
        </div>
        {% endif %}

        {# 獎項徽章 #}
        {% if product._awards %}
        <div class="awards-list">
          {% for award in product._awards %}
          <span class="award-badge">{{ award }}</span>
          {% endfor %}
        </div>
        {% endif %}

        <div class="quick-badges" style="margin-top: 20px;">
          {% if product.sake_type %}<span class="badge badge-primary">{{ product.sake_type }}</span>{% endif %}
          {% if product.rice_variety %}<span class="badge">{{ product.rice_variety }}</span>{% endif %}
          {% if product.seimaibuai %}<span class="badge">精米 {{ product.seimaibuai }}%</span>{% endif %}
          {% if product.abv %}<span class="badge">{{ product.abv }}% ABV</span>{% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{# ===== 詳細內容 ===== #}
<main class="container product-page">
<article class="product-detail">

{% if product.description %}
<section class="product-section">
  <h2>關於這款酒</h2>
  <p>{{ product.description }}</p>
</section>
{% endif %}

{% if product.tasting_note %}
<section class="product-section">
  <h2>品飲建議</h2>
  <p>{{ product.tasting_note }}</p>
</section>
{% endif %}

{% if product.pairing %}
<section class="product-section">
  <h2>搭餐建議</h2>
  <p>{{ product.pairing }}</p>
</section>
{% endif %}

<section class="product-section">
  <h2>規格</h2>
  <table class="sake-specs">
    <tbody>
      <tr><th>酒造</th><td>{{ product.brewery_name_jp | dash }}</td></tr>
      <tr><th>產地</th><td>{{ product.area_zhtw or product.area_jp | dash }}</td></tr>
      {% if product.sake_type %}<tr><th>酒類型</th><td>{{ product.sake_type }}</td></tr>{% endif %}
      {% if product.rice_variety %}<tr><th>使用米</th><td>{{ product.rice_variety }}</td></tr>{% endif %}
      {% if product.rice_origin %}<tr><th>米產地</th><td>{{ product.rice_origin }}</td></tr>{% endif %}
      {% if product.seimaibuai %}<tr><th>精米步合</th><td>{{ product.seimaibuai }}%</td></tr>{% endif %}
      {% if product.yeast %}<tr><th>酵母</th><td>{{ product.yeast }}</td></tr>{% endif %}
      {% if product.abv %}<tr><th>酒精度</th><td>{{ product.abv }}%</td></tr>{% endif %}
      {% if product.smv %}<tr><th>日本酒度</th><td>{{ product.smv }}</td></tr>{% endif %}
      {% if product.acidity %}<tr><th>酸度</th><td>{{ product.acidity }}</td></tr>{% endif %}
      {% if product.amino_acid %}<tr><th>氨基酸度</th><td>{{ product.amino_acid }}</td></tr>{% endif %}
    </tbody>
  </table>
</section>

{# 風味雷達圖 - 完整版,只在主內容區出現一次 #}
{% set has_flavor = product.flavor_f1_華やか and product.flavor_f1_華やか|float(0) > 0 %}
{% if has_flavor %}
{% set axes = [
  ('華麗', product.flavor_f1_華やか),
  ('芳醇', product.flavor_f2_芳醇),
  ('厚重', product.flavor_f3_重厚),
  ('穩重', product.flavor_f4_穏やか),
  ('辛口', product.flavor_f5_ドライ),
  ('輕快', product.flavor_f6_軽快)
] %}
{% set xs = [0, 0.866, 0.866, 0, -0.866, -0.866] %}
{% set ys = [-1, -0.5, 0.5, 1, 0.5, -0.5] %}
<section class="product-section">
  <h2>風味輪廓</h2>
  <div class="flavor-radar-container">
    <svg viewBox="0 0 300 300" class="flavor-radar" xmlns="http://www.w3.org/2000/svg">
      {% for r in [30, 60, 90, 120] %}
      <polygon points="{% for i in range(6) %}{{ 150 + r * xs[i] }},{{ 150 + r * ys[i] }} {% endfor %}" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="1"/>
      {% endfor %}
      {% for i in range(6) %}
      <line x1="150" y1="150" x2="{{ 150 + 120 * xs[i] }}" y2="{{ 150 + 120 * ys[i] }}" stroke="rgba(0,0,0,0.1)" stroke-width="1"/>
      {% endfor %}
      <polygon points="{% for i in range(6) %}{% set v = axes[i][1]|float(0) %}{{ 150 + 120 * v * xs[i] }},{{ 150 + 120 * v * ys[i] }} {% endfor %}" fill="{{ theme.primary }}" fill-opacity="0.3" stroke="{{ theme.primary }}" stroke-width="2"/>
      {% for i in range(6) %}
      {% set v = axes[i][1]|float(0) %}
      <circle cx="{{ 150 + 120 * v * xs[i] }}" cy="{{ 150 + 120 * v * ys[i] }}" r="4" fill="{{ theme.primary }}"/>
      {% endfor %}
      {% for i in range(6) %}
      <text x="{{ 150 + 145 * xs[i] }}" y="{{ 150 + 145 * ys[i] }}" text-anchor="middle" dominant-baseline="middle" font-size="14" font-weight="500" fill="#2C2C2C" font-family="Noto Sans TC, sans-serif">{{ axes[i][0] }}</text>
      {% endfor %}
    </svg>
    <div class="flavor-legend">
      {% for label, value in axes %}
      <div class="flavor-legend-item">
        <span class="flavor-legend-label">{{ label }}</span>
        <span class="flavor-legend-value">{{ "%.2f"|format(value|float(0)) }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  <p class="flavor-note">資料來源:Sakenowa 用戶評分整體</p>
</section>
{% endif %}

{% if product.flavor_tags %}
<section class="product-section">
  <h2>風味標籤</h2>
  <div class="flavor-tags">
    {% for tag in product.flavor_tags.split(',') %}
    {% if tag.strip() %}<span class="tag">{{ tag.strip() }}</span>{% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

</article>
</main>

<footer class="site-footer">
  <div class="container">
    <p><a href="{{ page_path }}breweries/{{ product.brewery_id | safe_id }}.html">← 返回 {{ product.brewery_name_jp }}</a></p>
    {% if product.sakenowa_brand_url %}
    <p class="footer-meta"><a href="{{ product.sakenowa_brand_url }}" rel="noopener" target="_blank">在 Sakenowa 查看更多資訊 →</a></p>
    {% endif %}
    <p class="footer-meta">最後更新:{{ generated_at }}</p>
  </div>
</footer>

{% include '_warning_bar.html.j2' %}
</body>
</html>
