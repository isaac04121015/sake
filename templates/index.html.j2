<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>日本酒造資料庫｜Sakego</title>
<meta name="description" content="日本酒造與產品資料庫,按地區瀏覽 {{ total_breweries }} 家酒造與 {{ total_products }} 款日本酒。">
<link rel="stylesheet" href="{{ page_path }}styles.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
<header class="site-header">
  <div class="container">
    <h1 class="site-title"><a href="{{ page_path }}index.html">日本酒造資料庫</a></h1>
    <p class="site-tagline">Sakego ｜ 探索 {{ total_breweries }} 家酒造、{{ total_products }} 款日本酒</p>
  </div>
</header>

{# Hero 區 - 用 Unsplash 情境圖當背景 #}
<section class="home-hero">
  <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1579952516518-12c1d8f3a05a?w=1600&q=80');"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <h2 class="hero-title">探索日本酒的世界</h2>
    <p class="hero-sub">從北海道到九州,{{ total_breweries }} 家酒造、{{ total_products }} 款銘柄一次掌握</p>
    <div class="hero-search">
      <input type="search" id="search-input" placeholder="搜尋酒造、銘柄或地區⋯" autocomplete="off">
      <div id="search-results" class="search-results" hidden></div>
    </div>
  </div>
</section>

<main class="container">

<section class="stats">
  <div class="stat">
    <span class="stat-num">{{ total_breweries }}</span>
    <span class="stat-label">酒造</span>
  </div>
  <div class="stat">
    <span class="stat-num">{{ total_products }}</span>
    <span class="stat-label">酒款</span>
  </div>
  <div class="stat">
    <span class="stat-num">{{ regions|length }}</span>
    <span class="stat-label">地區</span>
  </div>
</section>

{# 地區快速導覽 #}
<nav class="region-nav">
  {% for region in regions %}
  <a href="{{ page_path }}regions/{{ region.name | safe_id }}/" class="region-pill">
    <span class="region-pill-name">{{ region.name }}</span>
    <span class="region-pill-count">{{ region.brewery_count }}</span>
  </a>
  {% endfor %}
</nav>

{% for region in regions %}
<section class="region-block" id="region-{{ region.name | safe_id }}">
  <header class="region-header">
    <h2><a href="{{ page_path }}regions/{{ region.name | safe_id }}/">{{ region.name }}</a></h2>
    <span class="region-count">{{ region.brewery_count }} 家酒造</span>
  </header>

  {% for area, breweries in region.areas.items() %}
  <div class="area-block">
    <h3 class="area-name">{{ area }}</h3>
    <ul class="brewery-list">
      {% for brewery in breweries %}
      <li>
        <a href="{{ page_path }}breweries/{{ brewery.brewery_id | safe_id }}.html">
          {{ brewery.name_zhtw or brewery.name_jp }}
          {% if brewery.name_zhtw and brewery.name_zhtw != brewery.name_jp %}
          <span class="brewery-jp">{{ brewery.name_jp }}</span>
          {% endif %}
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endfor %}

</main>

<footer class="site-footer">
  <div class="container">
    <p>資料來源:<a href="https://sakenowa.com/" rel="noopener" target="_blank">Sakenowa Data Project</a>｜事實規格欄位來自各酒造官網</p>
    <p class="footer-meta">情境圖片來自 <a href="https://unsplash.com/" rel="noopener" target="_blank">Unsplash</a>(CC0/Unsplash License)</p>
    <p class="footer-meta">最後更新:{{ generated_at }}</p>
  </div>
</footer>

<script src="{{ page_path }}search.js"></script>
</body>
</html>
