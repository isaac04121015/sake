<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>日本酒造資料庫｜Sakego</title>
<meta name="description" content="探索 {{ total_breweries }} 家日本酒造、{{ total_products }} 款銘柄,按地區瀏覽。">
<link rel="stylesheet" href="{{ page_path }}styles.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
<header class="site-header">
  <div class="container">
    <h1 class="site-title"><a href="{{ page_path }}index.html">日本酒造資料庫</a></h1>
    <p class="site-tagline">Sakego ｜ 探索 {{ total_breweries }} 家酒造、{{ total_products }} 款日本酒</p>
  </div>
</header>

{# ===== 滿版奢華 Hero ===== #}
<section class="home-hero">
  <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1579952516518-12c1d8f3a05a?w=1920&q=85');"></div>
  <div class="hero-overlay"></div>
  <div class="hero-vignette"></div>
  <div class="hero-texture"></div>
  <div class="hero-deco-kanji">酒</div>
  <div class="hero-vert-text">SAKEGO · JAPAN SAKE DATABASE · 日本酒造資料庫</div>

  {# 金色光點粒子 #}
  <div class="hero-bokeh" style="left: 12%; top: 70%; width: 8px; height: 8px; --dx: 30px; --dur: 5s; --delay: 0s;"></div>
  <div class="hero-bokeh" style="left: 22%; top: 80%; width: 5px; height: 5px; --dx: -20px; --dur: 4s; --delay: 1s;"></div>
  <div class="hero-bokeh" style="left: 78%; top: 75%; width: 7px; height: 7px; --dx: 15px; --dur: 6s; --delay: 0.5s;"></div>
  <div class="hero-bokeh" style="left: 88%; top: 85%; width: 4px; height: 4px; --dx: -25px; --dur: 4.5s; --delay: 2s;"></div>
  <div class="hero-bokeh" style="left: 50%; top: 90%; width: 6px; height: 6px; --dx: 20px; --dur: 5.5s; --delay: 1.5s;"></div>

  <div class="container hero-content">
    <span class="hero-eyebrow hero-anim-1">JAPAN SAKE DATABASE</span>

    <div class="hero-ornament hero-anim-2">
      <span class="hero-orn-line"></span>
      <span class="hero-orn-dot"></span>
      <span class="hero-orn-dia"></span>
      <span class="hero-orn-dot"></span>
      <span class="hero-orn-line r"></span>
    </div>

    <h1 class="hero-title hero-anim-2">探索 <span class="hero-shimmer">日本酒</span> 的世界</h1>
    <p class="hero-sub hero-anim-3">從北海道到九州,{{ total_breweries }} 家酒造、{{ total_products }} 款銘柄一次掌握</p>

    <div class="hero-search hero-anim-4">
      <input type="search" id="search-input" placeholder="搜尋酒造、銘柄或地區⋯" autocomplete="off">
      <div id="search-results" class="search-results" hidden></div>
    </div>
  </div>

  {# 玻璃霧化統計條 (置底) #}
  <div class="hero-stats-strip hero-anim-4">
    <div class="hero-stat">
      <span class="hero-stat-num">{{ total_breweries }}</span>
      <span class="hero-stat-label">家酒造</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-num">{{ total_products }}</span>
      <span class="hero-stat-label">款銘柄</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-num">{{ regions|length }}</span>
      <span class="hero-stat-label">大地區</span>
    </div>
  </div>
</section>

{# ===== 品牌宣言 ===== #}
<section class="manifesto-strip">
  <div class="container">
    <span class="manifesto-eyebrow">OUR PHILOSOPHY</span>
    <p class="manifesto-text">每一瓶日本酒,都承載著釀造者的心意、土地的氣息,與數百年的工藝傳承。</p>
  </div>
</section>

{# ===== 地區排行 (rank-card) ===== #}
<section class="rankings-section">
  <div class="container">
    <span class="section-eyebrow">REGIONS</span>
    <h2 class="section-heading">依地區探索</h2>
    <p class="section-sub">日本九大地區,各有其風土與酒造傳統</p>

    <div class="rank-grid">
      {% for region in regions %}
      <a href="{{ page_path }}regions/{{ region.name | safe_id }}/" class="rank-card">
        <span class="rank-card-accent"></span>
        <span class="rank-num-bg">{{ loop.index }}</span>
        <span class="rank-ordinal">No. {{ "%02d"|format(loop.index) }}</span>
        <h3 class="rank-name">{{ region.name }}</h3>
        <p class="rank-prefectures">
          {% set areas_list = region.areas.keys() | list %}
          {{ areas_list[:6] | join('・') }}{% if areas_list|length > 6 %}⋯{% endif %}
        </p>
        <div class="rank-bar-track">
          {% set max_count = regions | map(attribute='brewery_count') | max %}
          <div class="rank-bar-fill" style="width: {{ (region.brewery_count / max_count * 100) | int }}%;"></div>
        </div>
        <span class="rank-count"><strong>{{ region.brewery_count }}</strong> 家酒造</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ===== 各地區酒造速覽 ===== #}
<main class="container">
  {% for region in regions %}
  <section class="region-block" id="region-{{ region.name | safe_id }}">
    <header class="region-header">
      <h2><a href="{{ page_path }}regions/{{ region.name | safe_id }}/">{{ region.name }}</a></h2>
      <span class="region-count">{{ region.brewery_count }} 家酒造</span>
    </header>

    {% for area, breweries in region.areas.items() %}
    <div class="area-block">
      <h3 class="area-name">{{ area }}</h3>
      <ul class="brewery-entries">
        {% for brewery in breweries[:8] %}
        {% set display_name = (brewery.name_zhtw or brewery.name_jp or '') | trim %}
        {% if display_name %}
        <li>
          <a href="{{ page_path }}breweries/{{ brewery.brewery_id | safe_id }}.html" class="brewery-entry">
            <div class="brewery-entry-body">
              <span class="brewery-entry-name">{{ display_name }}</span>
              {% if brewery.name_zhtw and brewery.name_zhtw != brewery.name_jp %}
              <span class="brewery-entry-jp">{{ brewery.name_jp }}</span>
              {% endif %}
            </div>
            <span class="brewery-entry-arrow">›</span>
          </a>
        </li>
        {% endif %}
        {% endfor %}
      </ul>
      {% if breweries|length > 8 %}
      <p style="margin-top: 12px; font-size: 0.85rem; color: var(--text-muted);">
        <a href="{{ page_path }}regions/{{ region.name | safe_id }}/" style="color: var(--primary);">
          查看 {{ area }} 全部 {{ breweries|length }} 家酒造 →
        </a>
      </p>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endfor %}
</main>

<footer class="site-footer">
  <div class="container">
    <p>資料來源:<a href="https://sakenowa.com/" rel="noopener" target="_blank">Sakenowa Data Project</a>｜事實規格欄位來自各酒造官網</p>
    <p class="footer-meta">情境圖片來自 <a href="https://unsplash.com/" rel="noopener" target="_blank">Unsplash</a>(CC0/Unsplash License)</p>
    <p class="footer-meta">最後更新:{{ generated_at }}</p>
  </div>
</footer>

{% include '_warning_bar.html.j2' %}

<script src="{{ page_path }}search.js"></script>
</body>
</html>
